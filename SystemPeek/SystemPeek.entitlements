<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is OFF: reading other processes' CPU/memory (for the top-process
	     metrics) requires process enumeration, which the sandbox blocks (EPERM).
	     The app still runs read-only, never as root, and makes no network access. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
