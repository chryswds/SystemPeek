<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Least privilege: App Sandbox ON, no extra entitlements.
	     All system metrics (host_statistics, hw.memsize, volume capacity)
	     work read-only within the sandbox. No network, camera, or mic. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
</dict>
</plist>
